<Window x:Class="Preparator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Preparator.ViewModels"
        Title="Preparator"
        Height="600" Width="1000"
        WindowStyle="None"
        Background="#1e1e1e">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <!-- SIDEBAR -->
        <StackPanel Background="#252526">

            <!-- LOGO -->
            <TextBlock Text="PREPARATOR"
                       Foreground="White"
                       FontSize="18"
                       Margin="20"
                       FontWeight="Bold"/>

            <!-- START -->
            <Button Style="{StaticResource NavButton}"
                    Command="{Binding ShowDashboardCommand}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE80F;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="16"
                               Margin="0,0,10,0"/>
                    <TextBlock Text="Start"/>
                </StackPanel>
            </Button>

            <!-- SYSTEM -->
            <Button Style="{StaticResource NavButton}"
                    Command="{Binding ShowSystemCommand}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE713;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="16"
                               Margin="0,0,10,0"/>
                    <TextBlock Text="System"></TextBlock>
                </StackPanel>
            </Button>

            <!-- POWER -->
            <Button Style="{StaticResource NavButton}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE945;" 
                       FontFamily="Segoe MDL2 Assets"
                       FontSize="16"
                       Margin="0,0,10,0"/>
                    <TextBlock Text="Power settings"/>
                </StackPanel>
            </Button>
            
            <!--`APPS -->
            <Button Style="{StaticResource NavButton}"
                    Command="{Binding ShowAppsCommand}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE71D;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="16"
                               Margin="0,0,10,0"/>
                    <TextBlock Text="Apps"/>
                </StackPanel>
            </Button>

        </StackPanel>
        
        <!-- CONTENT -->
        <ContentControl Grid.Column="1"
                        Content="{Binding CurrentView}"/>
        
    </Grid>
</Window>
