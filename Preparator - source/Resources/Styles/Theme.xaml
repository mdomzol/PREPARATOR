<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:System="clr-namespace:System;assembly=mscorlib">

    <!-- =========================================================
         🎯 BACKGROUND COLORS
    ========================================================== -->

    <Color x:Key="Color.Bg.App">#1e1e1e</Color>
    <Color x:Key="Color.Bg.Panel">#252526</Color>
    <Color x:Key="Color.Bg.Surface">#2b2b2e</Color>
    <Color x:Key="Color.Bg.Card">#2d2d30</Color>
    <Color x:Key="Color.Bg.Hover">#3a3a3a</Color>
    <Color x:Key="Color.Bg.Pressed">#1a1a1a</Color>

    <!-- =========================================================
         🎯 ACCENT COLORS
    ========================================================== -->

    <Color x:Key="Color.Accent.Primary">#3a8dde</Color>
    <Color x:Key="Color.Accent.PrimaryHover">#4a9cff</Color>
    <Color x:Key="Color.Accent.PrimarySoft">#5595e0</Color>

    <!-- =========================================================
         🎯 TEXT COLORS
    ========================================================== -->

    <Color x:Key="Color.Text.Primary">#ffffff</Color>
    <Color x:Key="Color.Text.Secondary">#cfcfcf</Color>
    <Color x:Key="Color.Text.Tertiary">#9aa0a6</Color>
    <Color x:Key="Color.Text.Disabled">#777777</Color>

    <!-- =========================================================
         🎯 STATUS COLORS
    ========================================================== -->

    <Color x:Key="Color.Status.Success">#4caf50</Color>
    <Color x:Key="Color.Status.Warning">#ff9800</Color>
    <Color x:Key="Color.Status.Error">#f44336</Color>
    <Color x:Key="Color.Status.Info">#2196f3</Color>

    <!-- =========================================================
         🎯 SHADOW COLORS
    ========================================================== -->

    <Color x:Key="Color.Shadow.Default">#000000</Color>
    <Color x:Key="Color.Shadow.Accent">#3a8dde</Color>

    <!-- =========================================================
         🎯 BRUSHES (UI USE)
    ========================================================== -->

    <!-- BACKGROUNDS -->
    <SolidColorBrush x:Key="Brush.Bg.App"
                     Color="{StaticResource Color.Bg.App}" />

    <SolidColorBrush x:Key="Brush.Bg.Panel"
                     Color="{StaticResource Color.Bg.Panel}" />

    <SolidColorBrush x:Key="Brush.Bg.Surface"
                     Color="{StaticResource Color.Bg.Surface}" />

    <SolidColorBrush x:Key="Brush.Bg.Card"
                     Color="{StaticResource Color.Bg.Card}" />

    <SolidColorBrush x:Key="Brush.Bg.Hover"
                     Color="{StaticResource Color.Bg.Hover}" />

    <SolidColorBrush x:Key="Brush.Bg.Pressed"
                     Color="{StaticResource Color.Bg.Pressed}" />

    <!-- ACCENT -->
    <SolidColorBrush x:Key="Brush.Accent.Primary"
                     Color="{StaticResource Color.Accent.Primary}" />

    <SolidColorBrush x:Key="Brush.Accent.PrimaryHover"
                     Color="{StaticResource Color.Accent.PrimaryHover}" />

    <SolidColorBrush x:Key="Brush.Accent.PrimarySoft"
                     Color="{StaticResource Color.Accent.PrimarySoft}" />

    <!-- TEXT -->
    <SolidColorBrush x:Key="Brush.Text.Primary"
                     Color="{StaticResource Color.Text.Primary}" />

    <SolidColorBrush x:Key="Brush.Text.Secondary"
                     Color="{StaticResource Color.Text.Secondary}" />

    <SolidColorBrush x:Key="Brush.Text.Tertiary"
                     Color="{StaticResource Color.Text.Tertiary}" />

    <SolidColorBrush x:Key="Brush.Text.Disabled"
                     Color="{StaticResource Color.Text.Disabled}" />

    <!-- STATUS -->
    <SolidColorBrush x:Key="Brush.Status.Success"
                     Color="{StaticResource Color.Status.Success}" />

    <SolidColorBrush x:Key="Brush.Status.Warning"
                     Color="{StaticResource Color.Status.Warning}" />

    <SolidColorBrush x:Key="Brush.Status.Error"
                     Color="{StaticResource Color.Status.Error}" />

    <SolidColorBrush x:Key="Brush.Status.Info"
                     Color="{StaticResource Color.Status.Info}" />

    <!-- =========================================================
         🎯 SHADOWS (reusable effects base colors)
    ========================================================== -->

    <Color x:Key="Color.Shadow.Dark">#000000</Color>

    <!-- =========================================================
         🎯 GLOBAL UI CONSTANTS (opcjonalne)
    ========================================================== -->

    <System:Double x:Key="CornerRadius.Small">6</System:Double>
    <System:Double x:Key="CornerRadius.Medium">10</System:Double>
    <System:Double x:Key="CornerRadius.Large">14</System:Double>

</ResourceDictionary>