<UserControl x:Class="Preparator.Views.PowerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer Background="#1e1e1e">
        <StackPanel Margin="20">

            <TextBlock Text="Power Settings"
                       Foreground="White"
                       FontSize="24"
                       Margin="0,0,0,20"/>
            
            <!-- KARTY -->
            <WrapPanel>
                
                <!-- HIGH PERFORMANCE -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="⚡ High Performance" FontSize="16"/>
                        <TextBlock Text="Maximum performance"
                                   Opacity="0.7"/>
                        <Button Content="Activate"
                                Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>
                
                <!-- BALANCED -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="⚖ Balanced" FontSize="16"/>
                        <TextBlock Text="Recommended mode"
                                   Opacity="0.7"/>
                        <Button Content="Activate"
                                Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>
                
                <!-- POWER SAVER -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="🔋 Power Saver" FontSize="16"/>
                        <TextBlock Text="Save Energy"
                                   Opacity="0.7"/>
                        <Button Content="Activate"
                                Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>
                
            </WrapPanel>
            
        </StackPanel>
    </ScrollViewer>
</UserControl>
