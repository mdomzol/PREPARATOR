<UserControl x:Class="Preparator.Views.AppsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer Background="#1e1e1e">
        <StackPanel Margin="20">

            <TextBlock Text="Applications"
                       Foreground="White"
                       FontSize="24"
                       Margin="0,0,0,20"/>

            <WrapPanel>

                <!-- CHROME -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="🌐 Google Chrome"/>
                        <Button Content="Install"
                                Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>

                <!-- 7ZIP -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="📦 7-Zip"/>
                        <Button Content="Install"
                                Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>

                <!-- VSCODE -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="💻 VS Code"/>
                        <Button Content="Install"
                                Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>

            </WrapPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>