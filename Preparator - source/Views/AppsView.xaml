<UserControl x:Class="Preparator.Views.AppsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Preparator.ViewModels"
             xmlns:helpers="clr-namespace:Preparator.Helpers">

    <!-- RESOURCES -->
    <UserControl.Resources>

        <helpers:PercentToWidthConverter x:Key="PercentToWidthConverter"/>
        <helpers:ChartConverter x:Key="ChartConverter"/>
        <helpers:ChartAreaConverter x:Key="ChartAreaConverter"/>

        <!-- CARD -->
        <DataTemplate x:Key="AppItemTemplate">
            <Border Margin="10"
                    Padding="15"
                    Width="200"
                    CornerRadius="10"
                    BorderThickness="2"
                    Cursor="Hand"
                    ToolTipService.ShowDuration="60000"
                    ToolTipService.InitialShowDelay="200">

                <Border.InputBindings>
                    <MouseBinding Gesture="LeftClick"
                                  Command="{Binding DataContext.ToggleAppCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                  CommandParameter="{Binding}"/>
                </Border.InputBindings>

                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="#2d2d30"/>
                        <Setter Property="BorderBrush" Value="#2d2d30"/>

                        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                        <Setter Property="RenderTransform">
                            <Setter.Value>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Setter.Value>
                        </Setter>

                        <Style.Triggers>

                            <!-- SELECTED -->
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter Property="BorderBrush" Value="#3a8dde"/>
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#3a8dde"
                                                          BlurRadius="20"
                                                          ShadowDepth="0"
                                                          Opacity="0.8"/>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>

                            <!-- HOVER -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#555"/>

                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.05" ScaleY="1.05"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>

                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                                         To="1.05"
                                                         Duration="0:0:0.15"/>
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                                         To="1.05"
                                                         Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>

                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                                         To="1"
                                                         Duration="0:0:0.15"/>
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                                         To="1"
                                                         Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>

                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Border.ToolTip>

                    <Border Background="#2b2b2e"
                            Padding="10"
                            CornerRadius="8"
                            BorderBrush="#3a3a3a"
                            BorderThickness="1">

                        <StackPanel>

                            <TextBlock Text="{Binding Name}"
                                       Foreground="White"
                                       FontWeight="SemiBold"/>

                            <TextBlock Text="{Binding IsSelected, StringFormat=Selected: {0}}"
                                       Foreground="#9aa0a6"
                                       FontSize="11"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                        
                    </Border>
                    
                </Border.ToolTip>

                <Grid>

                    <StackPanel HorizontalAlignment="Center">

                        <Image Source="{Binding IconPath}"
                               Width="40"
                               Height="40"
                               Margin="0,0,0,10"/>

                        <TextBlock Text="{Binding Name}"
                                   Foreground="White"
                                   FontSize="14"
                                   HorizontalAlignment="Center"/>

                    </StackPanel>

                    <!-- OVERLAY -->
                    <Border CornerRadius="10"
                            Background="#80000000"
                            IsHitTestVisible="False">

                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Opacity" Value="0"/>

                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                        <Setter Property="Opacity" Value="0.2"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>

                    <!-- CHECKMARK -->
                    <Border Width="24"
                            Height="24"
                            Background="#3a8dde"
                            CornerRadius="12"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="5"
                            IsHitTestVisible="False">

                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Opacity" Value="0"/>
                                <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>

                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0" ScaleY="0"/>
                                    </Setter.Value>
                                </Setter>

                                <Style.Triggers>

                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                        <Setter Property="Opacity" Value="1"/>

                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation
                                                        Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                                        To="1"
                                                        Duration="0:0:0.2"/>

                                                    <DoubleAnimation
                                                        Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                                        To="1"
                                                        Duration="0:0:0.2"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                    </DataTrigger>

                                    <DataTrigger Binding="{Binding IsSelected}" Value="False">
                                        <Setter Property="Opacity" Value="0"/>
                                        <Setter Property="RenderTransform">
                                            <Setter.Value>
                                                <ScaleTransform ScaleX="0" ScaleY="0"/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>

                                </Style.Triggers>
                            </Style>
                        </Border.Style>

                        <TextBlock Text="✔"
                                   Foreground="White"
                                   FontSize="14"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                </Grid>
            </Border>
        </DataTemplate>

    </UserControl.Resources>

    <!-- ROOT -->
    <Grid Background="#1e1e1e">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- HEADER -->
            <RowDefinition Height="*"/>     <!-- MAIN -->
            <RowDefinition Height="180"/>   <!-- FOOTER-->
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/> <!-- RIGHT PANEL -->
        </Grid.ColumnDefinitions>
            

        <Grid Grid.Row="0"
              Grid.ColumnSpan="2"
              Background="#252526">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- TITLE -->
                <RowDefinition Height="Auto"/> <!-- PRESETS -->
                <RowDefinition Height="Auto"/> <!-- TOOLBAR -->
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Grid.ColumnSpan="2"
                    Padding="20"
                    BorderBrush="#333"
                    BorderThickness="0,0,0,1">

                <Border.Effect>
                    <DropShadowEffect BlurRadius="10"
                                      ShadowDepth="2"
                                      Opacity="0.3"
                                      Color="Black"/>
                </Border.Effect>

                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#2b2b2e" Offset="0"/>
                        <GradientStop Color="#252526" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <StackPanel>

                    <!-- TITLE -->
                    <TextBlock Text="Applications"
                               Foreground="White"
                               FontSize="26"
                               FontWeight="SemiBold"
                               Margin="0,0,0,15"/>

                    <!-- ================= PRESETS (FLUENT SEGMENTED CONTROL) ================= -->
                    <Border Background="#2b2b2e"
                            CornerRadius="10"
                            Padding="6"
                            Margin="0,0,0,10">      

                        <Border.Resources>

                            <!-- Base style -->
                            <Style x:Key="PresetButtonStyle" TargetType="RadioButton">

                                <Setter Property="Foreground" Value="#cfcfcf"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="26,12"/>
                                <Setter Property="FontSize" Value="14"/>
                                <Setter Property="MinWidth" Value="110"/>
                                <Setter Property="Cursor" Value="Hand"/>

                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="RadioButton">

                                            <Grid>

                                                <!-- BACKGROUND (animated pill) -->
                                                <Border x:Name="bg"
                                                        Background="Transparent"
                                                        CornerRadius="8"
                                                        RenderTransformOrigin="0.5,0.5">

                                                    <Border.RenderTransform>
                                                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                                                    </Border.RenderTransform>

                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>

                                            </Grid>

                                            <ControlTemplate.Triggers>

                                                <!-- ACTIVE STATE -->
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="bg" Property="Background" Value="#3a8dde"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </Trigger>

                                                <!-- HOVER -->
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bg" Property="Background" Value="#3a3a3a"/>
                                                </Trigger>

                                                <!-- PRESS -->
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="bg" Property="RenderTransform">
                                                        <Setter.Value>
                                                            <ScaleTransform ScaleX="0.96" ScaleY="0.96"/>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>

                                            </ControlTemplate.Triggers>

                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>

                            </Style>

                        </Border.Resources>

                        <Grid>

                            <Border x:Name="SelectionHighlight"
                                    Background="#3a8dde"
                                    CornerRadius="8"
                                    Height="32"
                                    Opacity="0"
                                    HorizontalAlignment="Left"
                                    Width="0"
                                    RenderTransformOrigin="0.5,0.5">

                                <Border.RenderTransform>
                                    <TransformGroup>
                                        <TranslateTransform x:Name="HighlightTransform"/>
                                        <ScaleTransform x:Name="HighlightScale"
                                                        ScaleX="0.95"
                                                        ScaleY="0.95"/> 
                                    </TransformGroup>
                                </Border.RenderTransform>
                                
                            </Border>

                            <!-- SEGMENTED BAR -->
                            <ItemsControl x:Name="PresetList" 
                                          ItemsSource="{Binding PresetNames}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>

                                        <RadioButton Content="{Binding}"
                                                     GroupName="Presets"
                                                     Style="{StaticResource PresetButtonStyle}"
                                                     Margin="2,0"
                                                     Command="{Binding DataContext.ApplyPresetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                     CommandParameter="{Binding}">

                                            <RadioButton.ToolTip>
                                                <Border Background="#2b2b2e"
                                                        Padding="10"
                                                        CornerRadius="8"
                                                        BorderBrush="#3a3a3a"
                                                        BorderThickness="1">

                                                    <ItemsControl ItemsSource="{Binding DataContext.PresetPreviews[Binding], 
                                                                  RelativeSource={RelativeSource AncestorType=UserControl}}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Text="• {Binding}"
                                                                           Foreground="White"
                                                                           FontSize="11"/>      
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>

                                                </Border>
                                            </RadioButton.ToolTip>

                                        </RadioButton>

                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </Grid>

                    </Border>

                    <!-- TOOLBAR -->
                    <Grid Grid.Row="2"
                          Margin="0,15,0,0" Cursor="">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- SEARCH -->
                        <TextBox Grid.Column="0"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource SearchBoxStyle}"/>


                        <!-- CLEAR -->
                        <Button Grid.Column="1"
                                Command="{Binding ClearSelectionCommand}"
                                Cursor="Hand"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="#9aa0a6"
                                Padding="10,6">

                            <Button.Style>
                                <Style TargetType="Button">

                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">

                                                <Border x:Name="bg"
                                                        Background="Transparent"
                                                        CornerRadius="6"
                                                        Padding="{TemplateBinding Padding}">

                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>

                                                <ControlTemplate.Triggers>

                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bg" Property="Background" Value="#2d2d30"/>
                                                        <Setter Property="Foreground" Value="#ffffff"/>
                                                    </Trigger>

                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="bg" Property="Background" Value="#3a3a3a"/>
                                                    </Trigger>

                                                </ControlTemplate.Triggers>

                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>

                                </Style>
                            </Button.Style>

                            <TextBlock Text="Clear"/>
                        </Button>

                        <!-- INSTALL -->
                        <Button Grid.Column="2"
                                Command="{Binding InstallCommand}"
                                Cursor="Hand"
                                FontSize="14"
                                FontWeight="SemiBold"
                                MinWidth="140"
                                Height="42"
                                Margin="10,0,0,0">

                            <Button.Style>
                                <Style TargetType="Button">

                                    <Setter Property="Background" Value="#3a8dde"/>
                                    <Setter Property="Foreground" Value="White"/>

                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">

                                                <Border x:Name="bg"
                                                        Background="{TemplateBinding Background}"
                                                        CornerRadius="10"
                                                        Padding="14,6">

                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>

                                                <ControlTemplate.Triggers>

                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bg" Property="Background" Value="#4a9cff"/>
                                                    </Trigger>

                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="bg" Property="RenderTransform">
                                                            <Setter.Value>
                                                                <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>

                                                </ControlTemplate.Triggers>

                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>

                                </Style>
                            </Button.Style>

                            <StackPanel Orientation="Horizontal">

                                <TextBlock Text="Install"/>

                                <Border Background="#2d2d30"
                                        CornerRadius="6"
                                        Margin="8,0,0,0"
                                        Padding="6,1">

                                    <TextBlock Text="{Binding SelectedCount}"
                                               FontSize="12"/>
                                </Border>

                            </StackPanel>

                        </Button>

                    </Grid>

                    <!-- COUNT -->
                    <Border HorizontalAlignment="Left"
                            Margin="0,8,0,0"
                            Background="#1f1f22"
                            CornerRadius="14"
                            Padding="10,4">

                        <Border.Style>
                            <Style TargetType="Border">

                                <Style.Triggers>

                                    <!-- pulse on change -->
                                    <DataTrigger Binding="{Binding SelectedCount}" Value="1">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                     From="1" To="0.6"
                                                                     Duration="0:0:0.15"
                                                                     AutoReverse="True"/>       
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                    </DataTrigger>

                                </Style.Triggers>

                            </Style>
                        </Border.Style>

                        <StackPanel Orientation="Horizontal">

                            <Ellipse Width="8" Height="8" Fill="#3a8dde" Margin="0,0,6,0"/>

                            <TextBlock Text="{Binding SelectedCount, StringFormat={}{0} selected}"
                                       Foreground="#cfcfcf"
                                       FontSize="12"/>      
                        </StackPanel>

                    </Border>

                </StackPanel>
            </Border>

        </Grid>

    <!-- MAIN CONTENT (APPS) -->

        <Grid Grid.Row="1"
              Grid.Column="0">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- APPS -->
            <ListBox Grid.Row="1"
                     ItemsSource="{Binding GroupedApps}"
                     Background="Transparent"
                     BorderThickness="0"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                <ListBox.Resources>
                    <Style TargetType="ScrollBar" BasedOn="{StaticResource ModernScrollBar}" />
                </ListBox.Resources>

                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Focusable" Value="False"/>
                        <Setter Property="IsHitTestVisible" Value="False"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0"/>
                    </Style>
                </ListBox.ItemContainerStyle>

                <ListBox.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.ContainerStyle>
                            <Style TargetType="GroupItem">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="GroupItem">

                                            <StackPanel>
                                                
                                                <!-- HEADER -->
                                                <TextBlock Text="{Binding Name}"
                                                           Foreground="White"
                                                           FontSize="18"
                                                           Margin="10,20,0,10"/>
                                                
                                                <!-- ITEMS -->
                                                <ItemsControl ItemsSource="{Binding Items}"
                                                              ItemTemplate="{StaticResource AppItemTemplate}">

                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <WrapPanel/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    
                                                </ItemsControl>
                                                
                                            </StackPanel>
                                            
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </GroupStyle.ContainerStyle>
                    </GroupStyle>
                </ListBox.GroupStyle>
                
            </ListBox>
            
        </Grid>

        <!-- RIGHT PANEL -->
        <Border Grid.Row="1"
                Grid.Column="1"
                Background="#252526"
                BorderBrush="#333"
                BorderThickness="1,0,0,0">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Installation Log"
                           Foreground="White"
                           FontSize="16"
                           Margin="10"/>

                <Border Background="#141416"
                        CornerRadius="6"
                        Margin="10"
                        BorderBrush="#2a2a2d"
                        BorderThickness="1">

                    <ListBox x:Name="LogsList"
                             ItemsSource="{Binding InstallLogs}"
                             Background="Transparent"
                             BorderThickness="0"
                             Margin="10"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             Loaded="LogsList_Loaded">

                        <ListBox.Resources>
                            <Style TargetType="ScrollBar" BasedOn="{StaticResource ModernScrollBar}" />
                        </ListBox.Resources>

                        <!-- ITEM STYLE -->
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="2"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,2">

                                    <!-- TIMESTAMP -->
                                    <TextBlock Text="{Binding Timestamp, StringFormat={}{0:HH:mm:ss}}"
                                               Foreground="#777"
                                               FontFamily="Consolas"
                                               Margin="0,0,6,0"/>

                                    <!-- MESSAGE -->
                                    <TextBlock Text="{Binding Message}"
                                               FontFamily="Consolas"
                                               FontSize="11">

                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">

                                                <Setter Property="Foreground" Value="Gray"/>

                                                <Style.Triggers>

                                                    <DataTrigger Binding="{Binding Type}" Value="Install">
                                                        <Setter Property="Foreground" Value="Orange"/>
                                                    </DataTrigger>

                                                    <DataTrigger Binding="{Binding Type}" Value="Download">
                                                        <Setter Property="Foreground" Value="DeepSkyBlue"/>
                                                    </DataTrigger>

                                                    <DataTrigger Binding="{Binding Type}" Value="Success">
                                                        <Setter Property="Foreground" Value="LightGreen"/>
                                                    </DataTrigger>

                                                    <DataTrigger Binding="{Binding Type}" Value="Error">
                                                        <Setter Property="Foreground" Value="Red"/>
                                                    </DataTrigger>

                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>

                                    </TextBlock>

                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>

                    </ListBox>
                </Border>
            </Grid>

        </Border>

        <Border Grid.Row="2"
                Grid.ColumnSpan="2"
                Background="#252526"
                Padding="10"
                BorderBrush="#333"
                BorderThickness="1,1,0,0">
            
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="40"/>
                </Grid.ColumnDefinitions>
                
                <!-- ================= LEFT SCALE ================= -->
                <StackPanel Grid.Column="0" Margin="5">
                    <TextBlock Text="{Binding Stats.MaxDownload}" 
                               Foreground="#3a8dde"/>
                    
                    <TextBlock Text="0" Margin="0,80,0,0" 
                               Foreground="#3a8dde"/>
                </StackPanel>

                <!-- ================= CHART AREA ================= -->
                <Border Grid.Column="1"
                        Background="#1a1a1c"
                        CornerRadius="6"
                        Padding="5">
                    <Grid>
                        <Canvas x:Name="ChartCanvas"
                        Height="120"
                        ClipToBounds="True"
                        MouseMove="Chart_MouseMove"
                        MouseLeave="Chart_MouseLeave">

                            <!-- NETWORK -->

                            <!-- AREA -->
                            <Path>
                                <Path.Data>
                                    <MultiBinding Converter="{StaticResource ChartAreaConverter}">
                                        <Binding Path="Stats.DownloadHistory"/>
                                        <Binding ElementName="ChartCanvas" Path="ActualWidth"/>
                                    </MultiBinding>
                                </Path.Data>

                                <Path.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#803a8dde" Offset="0"/>
                                        <GradientStop Color="#003a8dde" Offset="1"/>
                                    </LinearGradientBrush>
                                </Path.Fill>
                            </Path>

                            <!-- LINE -->
                            <Polyline Stroke="#3a8dde" StrokeThickness="2">
                                <Polyline.Points>
                                    <MultiBinding Converter="{StaticResource ChartConverter}">
                                        <Binding Path="Stats.DownloadHistory"/>
                                        <Binding ElementName="ChartCanvas" Path="ActualWidth"/>
                                    </MultiBinding>
                                </Polyline.Points>
                            </Polyline>

                            <!-- DISK -->
                            <Path>
                                <Path.Data>
                                    <MultiBinding Converter="{StaticResource ChartAreaConverter}">
                                        <Binding Path="Stats.DiskWriteHistory"/>
                                        <Binding ElementName="ChartCanvas" Path="ActualWidth"/>
                                    </MultiBinding>
                                </Path.Data>

                                <Path.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#80f44336" Offset="0"/>
                                        <GradientStop Color="#00f44336" Offset="1"/>
                                    </LinearGradientBrush>
                                </Path.Fill>
                            </Path>

                            <Polyline Stroke="#f44336" StrokeThickness="2">
                                <Polyline.Points>
                                    <MultiBinding Converter="{StaticResource ChartConverter}">
                                        <Binding Path="Stats.DiskWriteHistory"/>
                                        <Binding ElementName="ChartCanvas" Path="ActualWidth"/>
                                    </MultiBinding>
                                </Polyline.Points>
                            </Polyline>

                            <!-- TOOLTIP -->
                            <Border x:Name="Tooltip"
                                    Background="#333"
                                    Padding="5"
                                    CornerRadius="4"
                                    Visibility="Collapsed"
                                    Panel.ZIndex="999">

                                <TextBlock x:Name="TooltipText"
                                   Foreground="White"/>

                            </Border>

                        </Canvas>

                        <!-- OVERLAY LEGEND (TOP LEFT) -->
                        <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                Margin="8"
                                Panel.ZIndex="10">

                            <StackPanel Orientation="Horizontal" Margin="0,0,15,0">
                                <Ellipse Width="10" Height="10" Fill="#3a8dde" Margin="0,0,5,0"/>
                                <TextBlock Text="Network:" Foreground="White"/>
                                <TextBlock Text="{Binding Stats.Download}" Foreground="#3a8dde"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="10" Height="10" Fill="#f44336" Margin="0,0,5,0"/>
                                <TextBlock Text="Disk:" Foreground="White"/>
                                <TextBlock Text="{Binding Stats.DiskWrite}" Foreground="#f44336"/>
                            </StackPanel>

                        </StackPanel>

                    </Grid>
                </Border>

            <!-- ================= RIGHT SCALE ================= -->
            <StackPanel Grid.Column="2" Margin="5">
                <TextBlock Text="{Binding Stats.MaxDisk}" 
                           Foreground="#f44336"/>
                
                <TextBlock Text="0" Margin="0,80,0,0" 
                           Foreground="#f44336"/>
            </StackPanel>

    </Grid>

        </Border>

    </Grid>

</UserControl>