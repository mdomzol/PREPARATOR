<UserControl x:Class="Preparator.Views.AppsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Preparator.ViewModels"
             xmlns:helpers="clr-namespace:Preparator.Helpers">

    <!-- DATA CONTEXT -->
    <UserControl.DataContext>
        <vm:AppsViewModel/>
    </UserControl.DataContext>

    <!-- RESOURCES -->
    <UserControl.Resources>

        <helpers:ActivePresetToBoolConverter x:Key="ActivePresetToBoolConverter"/>
        <helpers:PercentToWidthConverter x:Key="PercentToWidthConverter"/>
        <helpers:ChartConverter x:Key="ChartConverter"/>

        <!-- CARD -->
        <DataTemplate x:Key="AppItemTemplate">
            <Border Margin="10"
                    Padding="15"
                    Width="200"
                    CornerRadius="10"
                    BorderThickness="2"
                    Cursor="Hand">

                <Border.InputBindings>
                    <MouseBinding Gesture="LeftClick"
                                  Command="{Binding DataContext.ToggleAppCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                  CommandParameter="{Binding}"/>
                </Border.InputBindings>

                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="#2d2d30"/>
                        <Setter Property="BorderBrush" Value="#2d2d30"/>

                        <Style.Triggers>

                            <!-- SELECTED -->
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter Property="BorderBrush" Value="#3a8dde"/>
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#3a8dde"
                                                          BlurRadius="20"
                                                          ShadowDepth="0"
                                                          Opacity="0.8"/>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>

                            <!-- HOVER -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#555"/>
                            </Trigger>

                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Grid>

                    <StackPanel HorizontalAlignment="Center">

                        <Image Source="{Binding IconPath}"
                               Width="40"
                               Height="40"
                               Margin="0,0,0,10"/>

                        <TextBlock Text="{Binding Name}"
                                   Foreground="White"
                                   FontSize="14"
                                   HorizontalAlignment="Center"/>

                    </StackPanel>

                    <!-- OVERLAY -->
                    <Border CornerRadius="10"
                            Background="#80000000"
                            IsHitTestVisible="False">

                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Opacity" Value="0"/>

                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                        <Setter Property="Opacity" Value="0.2"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>

                    <!-- CHECKMARK -->
                    <Border Width="24"
                            Height="24"
                            Background="#3a8dde"
                            CornerRadius="12"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="5"
                            IsHitTestVisible="False">

                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Opacity" Value="0"/>
                                <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>

                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0" ScaleY="0"/>
                                    </Setter.Value>
                                </Setter>

                                <Style.Triggers>

                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                        <Setter Property="Opacity" Value="1"/>

                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation
                                                        Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                                        To="1"
                                                        Duration="0:0:0.2"/>

                                                    <DoubleAnimation
                                                        Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                                        To="1"
                                                        Duration="0:0:0.2"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                    </DataTrigger>

                                    <DataTrigger Binding="{Binding IsSelected}" Value="False">
                                        <Setter Property="Opacity" Value="0"/>
                                        <Setter Property="RenderTransform">
                                            <Setter.Value>
                                                <ScaleTransform ScaleX="0" ScaleY="0"/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>

                                </Style.Triggers>
                            </Style>
                        </Border.Style>

                        <TextBlock Text="✔"
                                   Foreground="White"
                                   FontSize="14"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                </Grid>
            </Border>
        </DataTemplate>

    </UserControl.Resources>

    <!-- ROOT -->
    <Grid Background="#1e1e1e">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#252526"
                Padding="15"
                BorderBrush="#333"
                BorderThickness="0,0,0,1">

            <StackPanel>

                <!-- HEADER -->
                <TextBlock Text="Applications"
                           Foreground="White"
                           FontSize="24"
                           Margin="0,0,0,10"/>

                <!-- PRESETS -->
                <ItemsControl ItemsSource="{Binding PresetNames}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="140"
                                    Height="80"
                                    Margin="5"
                                    CornerRadius="12"
                                    Background="#2d2d30"
                                    Cursor="Hand"
                                    Tag="{Binding}">

                                <Border.InputBindings>
                                    <MouseBinding Gesture="LeftClick"
                                                  Command="{Binding DataContext.ApplyPresetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  CommandParameter="{Binding}"/>
                                </Border.InputBindings>

                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BorderBrush" Value="#2d2d30"/>
                                        <Setter Property="BorderThickness" Value="2"/>

                                        <Style.Triggers>
                                            <!-- DataTrigger z MultiBinding -->
                                            <DataTrigger Value="True">
                                                <DataTrigger.Binding>
                                                    <MultiBinding Converter="{StaticResource ActivePresetToBoolConverter}">
                                                        <Binding Path="DataContext.ActivePreset" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                        <Binding Path="Tag" RelativeSource="{RelativeSource Self}"/>
                                                    </MultiBinding>
                                                </DataTrigger.Binding>
                                                <Setter Property="BorderBrush" Value="#3a8dde"/>
                                            </DataTrigger>

                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#3a3a3a"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding}"
                                               Foreground="White"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>

                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- TOOLBAR -->
                <Grid Margin="0,15,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- SEARCH -->
                    <TextBox Grid.Column="0"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource SearchBoxStyle}"/>


                    <!-- CLEAR -->
                    <Button Grid.Column="1"
                            Content="Clear"
                            Margin="10,0"
                            Command="{Binding ClearSelectionCommand}"
                            Style="{StaticResource WindowButtonStyle}"/>

                    <!-- INSTALL -->
                    <Button Grid.Column="2"
                            Content="{Binding SelectedCount, StringFormat=Install ({0})}"
                            Command="{Binding InstallCommand}"
                            Style="{StaticResource InstallButtonStyle}"/>
                </Grid>

            </StackPanel>
        </Border>

        <!-- SCROLL VIEWER -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">

            <StackPanel Margin="20">

                <!-- COUNT -->
                <TextBlock Text="{Binding SelectedCount, StringFormat=Selected: {0} apps}"
                           Foreground="White"
                           Opacity="0.7"
                           Margin="0,0,0,20"/>

                <!-- GROUPED APPS -->
                <ItemsControl ItemsSource="{Binding GroupedApps}">

                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.ContainerStyle>
                                <Style TargetType="GroupItem">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="GroupItem">

                                                <StackPanel>

                                                    <!-- HEADER -->
                                                    <TextBlock Text="{Binding Name}"
                                                               Foreground="White"
                                                               FontSize="18"
                                                               Margin="10,20,0,10"/>

                                                    <!-- ITEMS -->
                                                    <ItemsControl ItemsSource="{Binding Items}"
                                                                  ItemTemplate="{StaticResource AppItemTemplate}">

                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <WrapPanel/>
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>

                                                    </ItemsControl>

                                                </StackPanel>

                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </GroupStyle.ContainerStyle>
                        </GroupStyle>
                    </ItemsControl.GroupStyle>

                </ItemsControl>

            </StackPanel>

        </ScrollViewer>

        <Border Grid.Row="2"
                MaxHeight="180"
                Background="#252526"
                Padding="10"
                BorderBrush="#333"
                BorderThickness="1,1,0,0">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="40"/>
                </Grid.ColumnDefinitions>

                <!-- ================= LEFT SCALE ================= -->
                <StackPanel Grid.Column="0"
                            VerticalAlignment="Stretch"
                            Margin="5">

                    <TextBlock Text="{Binding Stats.MaxDownload, StringFormat={}{0:0.#}}"
                               Foreground="#3a8dde"/>

                    <TextBlock Text="0"
                               Foreground="#3a8dde"
                               VerticalAlignment="Bottom"
                               Margin="0,80,0,0"/>
                </StackPanel>

                <!-- ================= CHART AREA ================= -->
                <Grid Grid.Column="1">

                    <!-- CANVAS WRAPPER -->
                    <Border Background="#1e1e1e"
                            CornerRadius="6"
                            ClipToBounds="True">

                        <Canvas x:Name="ChartCanvas"
                                Height="120"
                                ClipToBounds="True"
                                MouseMove="Chart_MouseMove"
                                MouseLeave="Chart_MouseLeave">

                            <!-- NETWORK -->
                            <Polyline Stroke="#3a8dde"
                                      StrokeThickness="2">
                                <Polyline.Points>
                                    <MultiBinding Converter="{StaticResource ChartConverter}">
                                        <Binding Path="Stats.DownloadHistory"/>
                                        <Binding ElementName="ChartCanvas" Path="ActualWidth"/>
                                        <Binding Path="Stats.MaxDownload"/>
                                    </MultiBinding>
                                </Polyline.Points>
                            </Polyline>

                            <!-- DISK -->
                            <Polyline Stroke="#f44336"
                                      StrokeThickness="2">
                                <Polyline.Points>
                                    <MultiBinding Converter="{StaticResource ChartConverter}">
                                        <Binding Path="Stats.DiskWriteHistory"/>
                                        <Binding ElementName="ChartCanvas" Path="ActualWidth"/>
                                        <Binding Path="Stats.MaxDisk"/>
                                    </MultiBinding>
                                </Polyline.Points>
                            </Polyline>

                            <!-- TOOLTIP -->
                            <Border x:Name="Tooltip"
                                    Background="#333"
                                    Padding="5"
                                    CornerRadius="4"
                                    Visibility="Collapsed"
                                    Panel.ZIndex="999">

                                <TextBlock x:Name="TooltipText"
                                           Foreground="White"/>

                            </Border>

                        </Canvas>

                    </Border>

                    <!-- OVERLAY LEGEND (TOP LEFT) -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                Margin="8"
                                Panel.ZIndex="10">

                        <StackPanel Orientation="Horizontal" Margin="0,0,15,0">
                            <Ellipse Width="10" Height="10" Fill="#3a8dde" Margin="0,0,5,0"/>
                            <TextBlock Text="Network:" Foreground="White"/>
                            <TextBlock Text="{Binding Stats.Download}" Foreground="#3a8dde"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="10" Height="10" Fill="#f44336" Margin="0,0,5,0"/>
                            <TextBlock Text="Disk:" Foreground="White"/>
                            <TextBlock Text="{Binding Stats.DiskWrite}" Foreground="#f44336"/>
                        </StackPanel>

                    </StackPanel>

                </Grid>

                <!-- ================= RIGHT SCALE ================= -->
                <StackPanel Grid.Column="2"
                            VerticalAlignment="Stretch"
                            Margin="5">

                    <TextBlock Text="{Binding Stats.MaxDisk, StringFormat={}{0:0.#}}"
                               Foreground="#f44336"/>

                    <TextBlock Text="0"
                               Foreground="#f44336"
                               VerticalAlignment="Bottom"
                               Margin="0,80,0,0"/>

                </StackPanel>

            </Grid>

        </Border>

        <!-- RIGHT SIDE LOGS -->
        <Border Grid.Column="1"
                Background="#1e1e1e"
                CornerRadius="8"
                Margin="10"
                Padding="10">

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding InstallLogs}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}"
                                       Foreground="#cccccc"
                                       FontSize="13"
                                       Margin="0,2"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

        </Border>

    </Grid>

</UserControl>