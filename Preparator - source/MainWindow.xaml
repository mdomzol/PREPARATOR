<Window x:Class="Preparator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Preparator"
        Height="600" Width="1000"
        WindowStyle="None"
        Background="#1e1e1e">
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <!-- SIDEBAR -->
        <StackPanel Background="#252526">

            <TextBlock Text="PREPARATOR"
                       Foreground="White"
                       FontSize="18"
                       Margin="20"
                       FontWeight="Bold"/>
            
            <!-- START -->
            <ToggleButton Style="{StaticResource NavToggleButton}"
                          Command="{Binding ShowDashboardCommand}"
                          IsChecked="{Binding SelectedView, Converter={StaticResource StringToBoolConverter}, ConverterParameter=Dashboard}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0"/>
                    <TextBlock Text="Start"/>
                </StackPanel>
            </ToggleButton>

            <!-- SYSTEM -->
            <ToggleButton Style="{StaticResource NavToggleButton}"
                          Command="{Binding ShowSystemCommand}"
                          IsChecked="{Binding SelectedView, Converter={StaticResource StringToBoolConverter}, ConverterParameter=System}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0"/>
                    <TextBlock Text="System"/>
                </StackPanel>
            </ToggleButton>
            
        </StackPanel>
        
        <!-- CONTENT -->
        <ContentControl Grid.Column="1"
                        Content="{Binding CurrentView}">
            <ContentControl.Resources>
                <Style TargetType="ContentPresenter">
                    <Setter Property="Opacity" Value="0"/>
                    <Style.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation From="0" To="1" Duration="0:0:0.25"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Style.Triggers>
                </Style>
            </ContentControl.Resources>
        </ContentControl>
    </Grid>
</Window>
